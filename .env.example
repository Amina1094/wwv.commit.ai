# Bright Data API token (for Web Unlocker, SERP API)
# Get your token at: https://brightdata.com/cp/setting/users
BRIGHTDATA_API_TOKEN=your_api_token_here

# Zone names (find yours at brightdata.com/cp/zones)
BRIGHTDATA_UNLOCKER_ZONE=mcp_unlocker
BRIGHTDATA_SERP_ZONE=serp_api1

# Datacenter proxy (optional — for direct HTTP via brd.superproxy.io)
BRIGHTDATA_DC_HOST=brd.superproxy.io
BRIGHTDATA_DC_PORT=33335
BRIGHTDATA_DC_USER=brd-customer-hl_XXXXXXXX-zone-datacenter_proxy1
BRIGHTDATA_DC_PASS=your_dc_password

# Azure OpenAI Configuration (for AI insights, summarization, simulations)
AZURE_OPENAI_ENDPOINT=https://your-azure-openai-endpoint
AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Frontend API base URL (set in GitHub Actions for production builds)
# NEXT_PUBLIC_API_BASE_URL=https://your-render-backend-url.onrender.com
